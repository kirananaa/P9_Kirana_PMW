<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main colors -->
        <item name="colorPrimary">@color/primary_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_dark_red</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/black</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/surface_dark</item>
        <item name="colorOnSecondaryContainer">@color/primary_red</item>

        <item name="colorTertiary">@color/primary_light_red</item>
        <item name="colorOnTertiary">@color/black</item>

        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>

        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_on_dark</item>
        <item name="colorSurfaceVariant">@color/black</item>
        <item name="colorOnSurfaceVariant">@color/white</item>

        <!-- Outline and Accents -->
        <item name="colorOutline">@color/primary_red</item>
        <item name="colorError">@color/primary_red</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />
</resources>